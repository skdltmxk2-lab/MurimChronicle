# 루트편입(Next.js) 환경변수 예시
# 이 파일을 복사해 .env.local 로 만들고 값을 채우세요. (.env.local 은 커밋되지 않습니다)

# --- Supabase (브라우저에서 사용, 공개되어도 되는 키) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase 서버 전용 (관리자 권한 DB 접근) ---
# 절대 클라이언트/리포지토리에 노출하지 마세요.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (AI 검색 / 풀이 / 튜터 / 임베딩) ---
# 미설정 시 AI 기능은 503 을 반환합니다.
GEMINI_API_KEY=

# --- 광고 슬롯 ("true" 일 때만 표시) ---
NEXT_PUBLIC_ADS_ENABLED=false

# --- (선택) 데이터 가공 스크립트 전용 — Mathpix OCR ---
# scripts/ 의 일부 업로드/추출 스크립트에서만 사용합니다.
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
