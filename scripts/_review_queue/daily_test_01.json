      "difficulty": "easyMedium",
      "question": "$\\cos\\!\\left(\\sin^{-1}\\!\\left(-\\dfrac{1}{4}\\right)\\right)$의 값은?",
      "options": [
        {"id":"1","label":"1","text":"$\\dfrac{\\sqrt{15}}{4}$","contentType":"latex","image":""}
