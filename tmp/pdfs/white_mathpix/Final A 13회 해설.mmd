& =2 \pi \int_{0}^{\sqrt{3}} z \times \sqrt{1+z^{2}} \times \sqrt{1+\frac{z^{2}}{1+z^{2}}} d z \\
& =2 \pi \int_{0}^{\sqrt{3}} z \times \sqrt{1+2 z^{2}} d z \\
& =\pi \int_{0}^{\sqrt{3}} 2 z \times\left(1+2 z^{2}\right)^{\frac{1}{2}} d z \\
& =\frac{\pi}{2} \int_{0}^{\sqrt{3}} 4 z \times\left(1+2 z^{2}\right)^{\frac{1}{2}} d z
